# Copy this file to .env and fill in real values. Never commit .env (secrets).

PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/travelDB
JWT_SECRET=replace_with_a_long_random_secret
CORS_ORIGIN=http://localhost:1234,https://your-frontend-domain.vercel.app

# Razorpay: Dashboard → API Keys. Key Id + Key Secret MUST be from the same mode (both test or both live).
# If create-order returns "Authentication failed", regenerate Key Secret in the dashboard and paste BOTH again.
# Debug (no secrets): GET http://localhost:5000/api/payment/integration-status
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
# Frontend loads this Key Id from GET /api/payment/checkout-config; REACT_APP_RAZORPAY_KEY in frontend is optional (fallback only).

# SMTP credentials for invoice/email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
