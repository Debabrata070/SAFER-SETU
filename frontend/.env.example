# One variable per line. Names must start with REACT_APP_ (not EACT_APP_).
# No extra text on the same line as the URL.

REACT_APP_API_URL=http://localhost:5000

# Optional fallback; same value as Backend RAZORPAY_KEY_ID. Checkout also uses GET /api/payment/checkout-config.
REACT_APP_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxxx
